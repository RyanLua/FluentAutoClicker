<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="FluentAutoClicker.HotkeyControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FluentAutoClicker"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ContentDialog
            x:Name="HotkeyContentDialog"
            Title="Toggle hotkey"
            CloseButtonClick="HotkeyContentDialog_CloseButtonClick"
            CloseButtonText="Cancel"
            DefaultButton="Primary"
            PrimaryButtonClick="HotkeyContentDialog_PrimaryButtonClick"
            PrimaryButtonText="Save"
            SecondaryButtonClick="HotkeyContentDialog_SecondaryButtonClick"
            SecondaryButtonText="Reset">

            <TextBox
                x:Name="HotkeyTextBox"
                IsReadOnly="True"
                KeyDown="TextBox_KeyDown" />
        </ContentDialog>

        <Button
            x:Name="HotkeyButton"
            Click="HotkeyButton_Click"
            Content="F6" />
    </Grid>
</UserControl>
